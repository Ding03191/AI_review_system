# Copy this file to .env and fill in the values. Do NOT commit real secrets to VCS.
OPENAI_API_KEY=your_openai_api_key_here
SECRET_KEY=please_set_a_secure_random_value
# Optional
FLASK_ENV=development
DEBUG=True
FRONTEND_BASE_URL=http://127.0.0.1:8080/public
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://127.0.0.1:5000/api/auth/google/callback
ADMIN_EMAILS=teacher@example.com,admin@example.com
